# ============================================
# .gitignore - Order API Serverless Project
# ============================================

# Node.js / TypeScript
# --------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Build outputs
# -------------
dist/
build/
*.tsbuildinfo

# NestJS specific
# --------------
*.spec.ts
!*.d.ts
coverage/
.nyc_output/
test-results/

# AWS CDK
# -------
cdk.out/
cdk.context.json
*.cdk.json

# Lambda Layer (backend)
# ----------------------
backend/layer/

# Environment variables
# ---------------------
.env
.env.local
.env.*.local
*.env

# AWS Credentials & Sensitive Files
# -----------------------------------
api-commandes_credentials.csv
aws credentials.md
*.pem
*.key
*.crt

# Logs
# -----
logs.txt
*.log

# macOS
# -----
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
# -----
*~
.directory
.Trash-*

# Windows
# -------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# IDE
# ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Temporary files
# ---------------
tmp/
temp/
*.tmp
*.bak
*.backup

# Cache
# -----
.cache/
.parcel-cache/
.eslintcache

# Testing
# --------
.jest/
coverage/

# Lambda build artifacts
# ----------------------
dist-lambda/
lambda.zip
function.zip
layer.zip
layer-arn.txt

# Misc
# -----
*.tgz
*.tar.gz
